@namespace WorkflowFormEngine.Components
@using WorkflowFormEngine.WorkflowEngine
@using WorkflowFormEngine.WorkflowEngine.Models
@using WorkflowFormEngine.Services

@inject OptionService      OptionService
@inject ValidationService  ValidationService

@if (Step is not null)
{
    @foreach (var field in Step.Fields.OrderBy(f => f.Order))
    {
        @if (ConditionEvaluator.IsVisible(field.VisibleWhen, Context))
        {
            <div @key="field.Key">
                <DynamicComponent Type="@Resolve(field.FieldType)"
                                  Parameters="@Params(field)" />
            </div>
        }
    }
}

@code {
    [Parameter, EditorRequired] public StepDefinition Step    { get; set; } = default!;
    [Parameter, EditorRequired] public FormContext    Context  { get; set; } = default!;
    [Parameter] public EventCallback OnContextChanged { get; set; }

    [Parameter]
    public IReadOnlyDictionary<string, IReadOnlyList<string>> ValidationErrors { get; set; }
        = new Dictionary<string, IReadOnlyList<string>>();

    /// <summary>
    /// True once the user has clicked Next or Submit at least once on this step.
    /// Enables row-level error computation. Reset to false when navigating steps.
    /// </summary>
    [Parameter]
    public bool ValidationAttempted { get; set; }

    /// <summary>
    /// Snapshot of row counts per repeater, captured by WorkflowPage
    /// at the exact moment the user clicks Next or Submit.
    ///
    /// WHY THIS IS HERE (not computed inside DynamicForm):
    ///   After Next/Submit fails, _validationAttempted stays true so live
    ///   re-validation can clear resolved errors as the user edits.
    ///   But OnContextChanged also fires when the user clicks "Add Row",
    ///   which triggers RunValidation() — a brand-new empty row is now
    ///   present when ValidateRepeaterRows runs → errors appear immediately.
    ///
    ///   The fix: WorkflowPage captures row counts BEFORE validation
    ///   runs in Next()/Submit() and passes them here. OnContextChanged
    ///   live re-validation never updates this snapshot, so any row added
    ///   after the last explicit Next/Submit has an index >= the snapshot
    ///   count and is silently excluded from RowErrors.
    /// </summary>
    [Parameter]
    public IReadOnlyDictionary<string, int> ValidatedRowCounts { get; set; }
        = new Dictionary<string, int>();

    private readonly DependencyGraph _graph = new();

    protected override void OnParametersSet()
    {
        if (Step is not null) _graph.Build(Step.Fields);
    }

    public IEnumerable<string> GetVisibleFieldKeys() =>
        Step?.Fields
            .Where(f => ConditionEvaluator.IsVisible(f.VisibleWhen, Context))
            .Select(f => f.Key)
        ?? [];

    private static Type Resolve(string fieldType) => fieldType switch
    {
        "text"          => typeof(TextField),
        "number"        => typeof(NumberField),
        "date"          => typeof(DateField),
        "select"        => typeof(SelectField),
        "checkboxlist"  => typeof(CheckboxListField),
        "repeater"      => typeof(RepeaterField),
        _ => throw new NotSupportedException($"Unknown fieldType '{fieldType}'.")
    };

    private Dictionary<string, object?> Params(FieldDefinition field)
    {
        ValidationErrors.TryGetValue(field.Key, out var errs);

        IReadOnlyDictionary<int, IReadOnlyDictionary<string, IReadOnlyList<string>>> rowErrors
            = new Dictionary<int, IReadOnlyDictionary<string, IReadOnlyList<string>>>();

        if (field.FieldType == "repeater" &&
            ValidationAttempted &&
            Context.GetValue(field.Key) is List<Dictionary<string, object?>> rows)
        {
            // Only show errors for rows that existed when the user last clicked
            // Next/Submit. Rows added after that click are pristine — no errors
            // until the user explicitly triggers validation again.
            var snapshotCount = ValidatedRowCounts.TryGetValue(field.Key, out var c) ? c : 0;

            rowErrors = ValidationService
                .ValidateRepeaterRows(field, rows)
                .Where(kv => kv.Key < snapshotCount)
                .ToDictionary(
                    kv => kv.Key,
                    kv => (IReadOnlyDictionary<string, IReadOnlyList<string>>)
                          kv.Value.ToDictionary(
                              e => e.Key,
                              e => (IReadOnlyList<string>)e.Value,
                              StringComparer.OrdinalIgnoreCase));
        }

        return new Dictionary<string, object?>
        {
            [nameof(FieldComponentBase.Field)]            = field,
            [nameof(FieldComponentBase.Value)]            = Context.GetValue(field.Key),
            [nameof(FieldComponentBase.OnValueChanged)]   = EventCallback.Factory.Create<object?>(
                                                                this, v => OnFieldChanged(field.Key, v)),
            [nameof(FieldComponentBase.FormContext)]      = Context,
            [nameof(FieldComponentBase.OptionService)]    = OptionService,
            [nameof(FieldComponentBase.ValidationErrors)] = errs ?? (IReadOnlyList<string>)[],
            [nameof(FieldComponentBase.RowErrors)]        = rowErrors,
        };
    }

    private async Task OnFieldChanged(string key, object? value)
    {
        Context.SetValue(key, value);
        foreach (var d in _graph.GetAllDownstream(key))
            Context.Reset(d);
        ClearHiddenFields();
        await OnContextChanged.InvokeAsync();
        StateHasChanged();
    }

    private void ClearHiddenFields()
    {
        if (Step is null) return;
        foreach (var f in Step.Fields)
            if (!ConditionEvaluator.IsVisible(f.VisibleWhen, Context))
                Context.Reset(f.Key);
    }
}
