@namespace WorkflowFormEngine.Components
@inherits FieldComponentBase

<div class="mb-3">
    <label class="form-label" for="@_id">
        @Field.Label
        @if (Field.Required)
        {
            <span class="text-danger ms-1" title="Required">*</span>
        }
    </label>
    <textarea id="@_id"
              class="form-control @(HasErrors ? "is-invalid" : "")"
              rows="@Field.Rows"
              placeholder="@(Field.Placeholder ?? $"Enter {Field.Label.ToLower()}…")"
              @oninput="OnInput">@Value?.ToString()</textarea>
    @if (HasErrors)
    {
        <div class="invalid-feedback d-block">
            @foreach (var e in ValidationErrors)
            {
                <div><i class="bi bi-exclamation-circle-fill me-1"></i>@e</div>
            }
        </div>
    }
</div>

@code {
    private string _id      = string.Empty;
    private bool   HasErrors => ValidationErrors.Count > 0;

    protected override void OnInitialized() =>
        _id = $"field-{Field.Key.ToLowerInvariant()}";

    private async Task OnInput(ChangeEventArgs e) =>
        await OnValueChanged.InvokeAsync(e.Value);
}
