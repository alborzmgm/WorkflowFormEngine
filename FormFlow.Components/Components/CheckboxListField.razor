@namespace FormFlow.Components
@inherits FieldComponentBase

<div class="mb-3">
    <fieldset>
        <legend class="form-label">
            @Field.Label
            @if (Field.Required)
            {
                <span class="text-danger ms-1" title="Required" aria-label="required">*</span>
            }
            @if (_selections.Count > 0)
            {
                <span class="wfe-checkbox-badge">@_selections.Count</span>
            }
        </legend>

        @if (_loading)
        {
            <div class="d-flex flex-column gap-2">
                <div class="wfe-shimmer" style="height:42px"></div>
                <div class="wfe-shimmer" style="height:42px; width:85%"></div>
                <div class="wfe-shimmer" style="height:42px; width:70%"></div>
            </div>
            <div class="form-text text-muted mt-2">
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                Loading @Field.Label options…
            </div>
        }
        else if (_options.Count == 0 && !_parentHasValue)
        {
            <div class="form-text text-muted">
                <i class="bi bi-arrow-up-circle me-1"></i>
                Please select <strong>@Field.DependsOn</strong> first.
            </div>
        }
        else if (_options.Count == 0)
        {
            <div class="form-text text-muted fst-italic">No options available.</div>
        }
        else
        {
            <div class="@(_options.Count > 6 ? "wfe-checkbox-scroll" : "")">
                <div class="wfe-checkbox-grid">
                    @foreach (var opt in _options)
                    {
                        var optId   = $"{_baseId}-{opt.Value}";
                        var chk     = _selections.Contains(opt.Value);
                        var itemCss = "wfe-checkbox-item" + (chk ? " wfe-checkbox-item--checked" : "");

                        <label class="@itemCss" for="@optId">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="@optId"
                                   value="@opt.Value"
                                   checked="@chk"
                                   @onchange="@(e => Toggle(opt.Value, e))" />
                            <span class="form-check-label">@opt.Label</span>
                        </label>
                    }
                </div>
            </div>

            @if (_options.Count > 3)
            {
                <div class="wfe-checkbox-toolbar">
                    <button type="button" class="btn btn-link" @onclick="SelectAll">
                        <i class="bi bi-check2-all me-1"></i>Select all
                    </button>
                    <span class="divider">·</span>
                    <button type="button" class="btn btn-link text-secondary" @onclick="ClearAll">
                        <i class="bi bi-x-circle me-1"></i>Clear all
                    </button>
                </div>
            }
        }

        @if (HasErrors)
        {
            <div class="invalid-feedback d-block mt-2">
                @foreach (var e in ValidationErrors)
                {
                    <div><i class="bi bi-exclamation-circle-fill me-1"></i>@e</div>
                }
            </div>
        }
    </fieldset>
</div>

@code {
    private List<OptionItem> _options     = [];
    private HashSet<string>  _selections  = new(StringComparer.OrdinalIgnoreCase);
    private bool             _loading     = false;
    private string           _baseId      = string.Empty;
    private object?          _lastParent  = new(); // sentinel — never equals a real value
    private bool             _initialized = false; // becomes true after first options load

    private bool HasErrors       => ValidationErrors.Count > 0;
    private bool _parentHasValue =>
        Field.DependsOn is null || (FormContext?.HasValue(Field.DependsOn) ?? false);

    protected override void OnInitialized()
    {
        _baseId = $"chk-{Field.Key.ToLowerInvariant()}";
        // Restore selections from FormContext immediately.
        // This is what makes back-navigation work — the values are already
        // in FormContext; we just need to read them before anything clears them.
        SyncFromContext();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Always sync first so context values are reflected before any early return.
        SyncFromContext();

        if (Field.DataSource is null || OptionService is null || FormContext is null)
            return;

        var currentParent = Field.DependsOn is not null
            ? FormContext.GetValue(Field.DependsOn)
            : null;

        // After first load, skip if the parent value has not changed.
        if (_initialized && Equals(currentParent, _lastParent)) return;

        // Determine whether this is a genuine mid-session parent change
        // (user picked a different parent) vs. first mount (back navigation).
        //
        // KEY FIX: on first mount (_initialized = false), we do NOT clear
        // _selections — SyncFromContext() already restored them from FormContext.
        // We only wipe selections when the parent genuinely changes during
        // an active session, which means stale child values must be discarded.
        bool parentChangedMidSession = _initialized &&
                                       !Equals(currentParent, _lastParent);

        _lastParent  = currentParent;
        _initialized = true;
        _loading     = true;
        _options     = [];

        if (parentChangedMidSession)
        {
            _selections.Clear();
            await PushValue(); // also clear the stale value stored in FormContext
        }

        StateHasChanged();

        var loaded = await OptionService.GetOptionsAsync(Field.DataSource, FormContext);
        _options   = [.. loaded];
        _loading   = false;
    }

    private async Task Toggle(string value, ChangeEventArgs e)
    {
        if (e.Value is true) _selections.Add(value);
        else                 _selections.Remove(value);
        await PushValue();
    }

    private async Task SelectAll()
    {
        _selections = [.. _options.Select(o => o.Value)];
        await PushValue();
    }

    private async Task ClearAll()
    {
        _selections.Clear();
        await PushValue();
    }

    private async Task PushValue()
    {
        var payload = _selections.Count > 0
            ? (object?)_selections.ToList()
            : null;
        await OnValueChanged.InvokeAsync(payload);
    }

    private void SyncFromContext()
    {
        if (Value is List<string> list)
            _selections = new HashSet<string>(list, StringComparer.OrdinalIgnoreCase);
        else if (Value is null)
            _selections.Clear();
    }
}
